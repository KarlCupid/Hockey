{
  "name": "franchise-ice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:report": "npm run build && node scripts/build-report.mjs",
    "check": "npm run typecheck && npm test && npm run test:smoke && npm run build",
    "test": "vitest run --config vitest.config.ts",
    "test:phase10": "vitest run --config vitest.config.ts src/tests/phase10LeagueRules.test.ts",
    "test:phase11": "vitest run --config vitest.config.ts src/tests/phase11PublicBeta.test.ts",
    "test:phase12": "vitest run --config vitest.config.ts src/tests/phase12ClosedBetaPolish.test.ts",
    "test:release": "npm run test:smoke && npm run test:phase11 && npm run test:phase12",
    "test:smoke": "vitest run --config vitest.config.ts src/tests/phase8ReleaseCandidate.test.ts src/tests/phase9Customization.test.ts src/tests/phase10LeagueRules.test.ts src/tests/phase11PublicBeta.test.ts src/tests/phase12ClosedBetaPolish.test.ts src/tests/phase13FacilityLayout.test.ts",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "localforage": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0",
    "zustand": "^5.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
